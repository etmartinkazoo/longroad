---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { property } from '../data/property';
import { galleryImages, type GalleryImage } from '../data/images';

const order: GalleryImage['category'][] = [
  'Exterior',
  'Interior',
  'Gardens & Grounds',
  'Outdoor Living',
];

const categoryDescriptions: Record<GalleryImage['category'], string> = {
  Exterior: 'The residence and its façades, in every season.',
  Interior: 'A walk through the principal rooms.',
  'Gardens & Grounds': 'Established plantings, brick paths and the wooded ravine.',
  'Outdoor Living': 'Terraces, dining and the stone outdoor kitchen.',
};

const grouped = order.map((cat) => ({
  category: cat,
  description: categoryDescriptions[cat],
  images: galleryImages.filter((g) => g.category === cat),
}));

const totalCount = galleryImages.length;
---

<Layout
  pageId="gallery"
  title={`Gallery — ${property.shortName}`}
  description={`A photographic tour of ${property.shortName}: ${totalCount} images of the residence, gardens and grounds.`}
>
  <!-- ========== PAGE HEADER ========== -->
  <header class="gallery-header">
    <div class="narrow gallery-header-inner">
      <p class="eyebrow">A Visual Tour</p>
      <h1 class="display-h1">The Gallery</h1>
      <div class="ornament"><span class="ornament-glyph">·  ·  ·</span></div>
      <p class="lede">
        A photographic record of {property.shortName} — the architecture, the rooms, the gardens.
        Click any image to view it in detail.
      </p>
    </div>
    <nav class="gallery-jump" aria-label="Gallery sections">
      {grouped.map((g) => (
        <a href={`#${g.category.toLowerCase().replace(/[^a-z]+/g, '-')}`}>{g.category}</a>
      ))}
    </nav>
  </header>

  <!-- ========== CATEGORY SECTIONS ========== -->
  {grouped.map((group, idx) => (
    <section
      class={`gallery-section ${idx % 2 === 1 ? 'gallery-alt' : ''}`}
      id={group.category.toLowerCase().replace(/[^a-z]+/g, '-')}
    >
      <div class="container">
        <div class="gallery-section-head">
          <p class="eyebrow">Chapter {String(idx + 1).padStart(2, '0')}</p>
          <h2 class="display-h2">{group.category}</h2>
          <p class="gallery-section-desc">{group.description}</p>
          <div class="ornament"><span class="ornament-glyph">·  ·  ·</span></div>
        </div>

        <div class="gallery-grid">
          {group.images.map((img, i) => (
            <figure
              class={`gallery-item gallery-item-${(i % 6) + 1}`}
              data-full={img.src.src}
              data-alt={img.alt}
              tabindex="0"
              role="button"
              aria-label={`Open larger view: ${img.alt}`}
            >
              <Image
                src={img.src}
                alt={img.alt}
                widths={[400, 700, 1100]}
                sizes="(min-width: 1100px) 33vw, (min-width: 700px) 50vw, 100vw"
                class="gallery-img"
              />
              <figcaption>{img.alt}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- ========== CTA ========== -->
  <section class="gallery-cta">
    <div class="narrow gallery-cta-inner">
      <p class="eyebrow eyebrow-light">In Person</p>
      <h2 class="display-h2 cta-title">Photographs only suggest what the residence reveals in person.</h2>
      <a href="/contact" class="btn btn-gold">Arrange a Visit</a>
    </div>
  </section>

  <!-- ========== LIGHTBOX ========== -->
  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Image viewer">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close viewer">&times;</button>
    <button class="lightbox-prev" id="lightbox-prev" aria-label="Previous image">&#8249;</button>
    <button class="lightbox-next" id="lightbox-next" aria-label="Next image">&#8250;</button>
    <figure class="lightbox-figure">
      <img id="lightbox-img" alt="" />
      <figcaption id="lightbox-caption"></figcaption>
    </figure>
  </div>
</Layout>

<style>
  .gallery-header {
    padding: 6rem 0 3rem;
    text-align: center;
    background: var(--ivory-soft);
    border-bottom: 1px solid rgba(26, 29, 36, 0.08);
  }
  .gallery-header h1 { margin-bottom: 0.5rem; }
  .gallery-header .lede { margin-top: 1.25rem; }

  .gallery-jump {
    margin: 2.5rem auto 0;
    display: flex; flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    max-width: 900px;
    border-top: 1px solid rgba(26, 29, 36, 0.12);
    border-bottom: 1px solid rgba(26, 29, 36, 0.12);
  }
  .gallery-jump a {
    flex: 1 1 auto;
    text-align: center;
    padding: 1.1rem 1.25rem;
    font-family: var(--sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--ink-soft);
    border-left: 1px solid rgba(26, 29, 36, 0.12);
    transition: color 200ms ease, background 200ms ease;
  }
  .gallery-jump a:first-child { border-left: none; }
  .gallery-jump a:hover { color: var(--gold-deep); background: rgba(156, 124, 52, 0.06); }

  .gallery-section {
    padding: 6rem 0;
    scroll-margin-top: 80px;
  }
  .gallery-alt { background: var(--paper); }

  .gallery-section-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 3.5rem;
  }
  .gallery-section-desc {
    font-style: italic;
    color: var(--slate);
    font-size: 1.1rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 220px;
    gap: 1rem;
  }
  .gallery-item {
    position: relative;
    margin: 0;
    overflow: hidden;
    grid-column: span 2;
    grid-row: span 1;
    cursor: zoom-in;
    background: var(--ink-soft);
    box-shadow: 0 8px 22px rgba(20, 22, 28, 0.14);
    transition: transform 350ms ease, box-shadow 350ms ease;
  }
  .gallery-item:hover, .gallery-item:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 18px 36px rgba(20, 22, 28, 0.22);
    outline: none;
  }
  .gallery-item:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 4px;
  }
  .gallery-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 600ms ease;
  }
  .gallery-item:hover .gallery-img { transform: scale(1.04); }
  .gallery-item figcaption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1rem 1rem 0.85rem;
    background: linear-gradient(0deg, rgba(20, 22, 28, 0.85) 0%, rgba(20, 22, 28, 0) 100%);
    color: var(--ivory);
    font-family: var(--serif-body);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.3;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 250ms ease, transform 250ms ease;
  }
  .gallery-item:hover figcaption,
  .gallery-item:focus-visible figcaption { opacity: 1; transform: none; }

  /* mosaic feature spans */
  .gallery-item-1 { grid-column: span 3; grid-row: span 2; }
  .gallery-item-4 { grid-row: span 2; }

  @media (max-width: 1100px) {
    .gallery-grid { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 200px; }
    .gallery-item { grid-column: span 2; grid-row: span 1; }
    .gallery-item-1 { grid-column: span 2; grid-row: span 2; }
    .gallery-item-4 { grid-row: span 1; }
  }
  @media (max-width: 700px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 180px; gap: 0.75rem; }
    .gallery-item, .gallery-item-1, .gallery-item-4 { grid-column: span 2; grid-row: span 1; }
    .gallery-item figcaption { opacity: 1; transform: none; font-size: 0.85rem; }
  }

  /* CTA */
  .gallery-cta {
    background: var(--ink);
    color: var(--ivory);
    padding: 6rem 0;
    text-align: center;
  }
  .eyebrow-light { color: var(--rule); }
  .cta-title { color: var(--ivory); margin-bottom: 2rem; }

  /* ========== LIGHTBOX ========== */
  .lightbox {
    position: fixed; inset: 0;
    background: rgba(12, 14, 20, 0.96);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 2rem;
  }
  .lightbox.is-open { display: flex; }
  .lightbox-figure {
    margin: 0;
    max-width: 92vw;
    max-height: 92vh;
    display: flex; flex-direction: column; align-items: center;
    gap: 1rem;
  }
  .lightbox-figure img {
    max-width: 92vw;
    max-height: 80vh;
    object-fit: contain;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
  }
  .lightbox-figure figcaption {
    color: rgba(246, 241, 230, 0.88);
    font-family: var(--serif-body);
    font-style: italic;
    font-size: 1.05rem;
    text-align: center;
    max-width: 700px;
  }
  .lightbox-close, .lightbox-prev, .lightbox-next {
    position: absolute;
    background: transparent;
    border: 1px solid rgba(246, 241, 230, 0.4);
    color: var(--ivory);
    cursor: pointer;
    font-family: var(--serif-display);
    transition: background 200ms ease, border-color 200ms ease;
  }
  .lightbox-close:hover, .lightbox-prev:hover, .lightbox-next:hover {
    background: rgba(246, 241, 230, 0.12);
    border-color: var(--rule);
  }
  .lightbox-close {
    top: 1.5rem; right: 1.5rem;
    width: 48px; height: 48px;
    font-size: 1.6rem;
    line-height: 1;
    border-radius: 50%;
  }
  .lightbox-prev, .lightbox-next {
    top: 50%;
    transform: translateY(-50%);
    width: 56px; height: 56px;
    font-size: 2rem;
    line-height: 1;
    border-radius: 50%;
  }
  .lightbox-prev { left: 1.5rem; }
  .lightbox-next { right: 1.5rem; }
  @media (max-width: 600px) {
    .lightbox-prev, .lightbox-next { width: 44px; height: 44px; font-size: 1.5rem; }
    .lightbox-prev { left: 0.5rem; }
    .lightbox-next { right: 0.5rem; }
    .lightbox-close { top: 0.75rem; right: 0.75rem; }
  }
</style>

<script>
  type Item = { src: string; alt: string };

  const items: Item[] = Array.from(document.querySelectorAll<HTMLElement>('.gallery-item')).map((el) => ({
    src: el.dataset.full || '',
    alt: el.dataset.alt || '',
  }));

  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const img = document.getElementById('lightbox-img') as HTMLImageElement;
  const caption = document.getElementById('lightbox-caption') as HTMLElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;
  const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;

  let currentIndex = 0;

  const open = (idx: number) => {
    currentIndex = idx;
    const item = items[idx];
    img.src = item.src;
    img.alt = item.alt;
    caption.textContent = item.alt;
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const close = () => {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  const step = (delta: number) => {
    const next = (currentIndex + delta + items.length) % items.length;
    open(next);
  };

  document.querySelectorAll<HTMLElement>('.gallery-item').forEach((el, idx) => {
    el.addEventListener('click', () => open(idx));
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        open(idx);
      }
    });
  });

  closeBtn.addEventListener('click', close);
  prevBtn.addEventListener('click', () => step(-1));
  nextBtn.addEventListener('click', () => step(1));
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') step(-1);
    if (e.key === 'ArrowRight') step(1);
  });
</script>
